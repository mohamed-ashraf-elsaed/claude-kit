# claude-kit PHPStan base config — referenced from the host phpstan.neon via
# `includes:`. Lives in vendor/, so `composer update` propagates rule changes.
# The host file only adds its own `paths:` on top of this.
includes:
    - ../../../../larastan/larastan/extension.neon
    - ../../../../nesbot/carbon/extension.neon
    - ../../../../phpstan/phpstan-strict-rules/rules.neon

parameters:
    level: 7
