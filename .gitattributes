* text=auto eol=lf

# Keep runtime scripts executable in checkouts and dist archives.
runtime/quality-checks.sh          text eol=lf
runtime/hooks/stop-validate.sh     text eol=lf
stubs/githooks/pre-commit          text eol=lf

# Exclude development-only files from the distributed Composer package.
/.github            export-ignore
/.claude            export-ignore
AGENTS.md           export-ignore
llms.txt            export-ignore
/.githooks          export-ignore
/docs               export-ignore
/tests              export-ignore
.editorconfig       export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
phpunit.xml         export-ignore
CONTRIBUTING.md     export-ignore
CODE_OF_CONDUCT.md  export-ignore
SECURITY.md         export-ignore
RELEASING.md        export-ignore
